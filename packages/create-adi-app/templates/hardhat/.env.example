# ADI Chain dApp — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your wallet private key (without 0x prefix is fine)
TESTNET_PRIVATE_KEY=your_private_key_here

# Mainnet private key (only needed if deploying to mainnet)
MAINNET_PRIVATE_KEY=your_mainnet_private_key_here

# Optional: Block explorer API key for contract verification
EXPLORER_API_KEY=your_explorer_api_key_here
